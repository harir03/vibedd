# =============================================================================
# TATVA — Environment Variables
# Copy this file to .env and customize values for your environment
# =============================================================================

# --- Neo4j (Knowledge Graph) ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=tatva_dev_2026
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_HEAP_INITIAL=512m
NEO4J_HEAP_MAX=1G
NEO4J_PAGECACHE=512m

# --- PostgreSQL (Operational Metadata & Audit) ---
POSTGRES_DB=tatva
POSTGRES_USER=tatva
POSTGRES_PASSWORD=tatva_dev_2026
POSTGRES_PORT=5432

# --- Elasticsearch (Full-text + Vector Search) ---
ES_PORT=9200
ES_HEAP=512m

# --- Kafka (Event Streaming) ---
KAFKA_PORT=9092
KAFKA_RETENTION_HOURS=168

# --- Zookeeper ---
ZK_PORT=2181

# --- Redis (Caching & Sessions) ---
REDIS_PORT=6379
REDIS_MAXMEMORY=256mb

# --- MinIO (Object Storage) ---
MINIO_ROOT_USER=tatva_admin
MINIO_ROOT_PASSWORD=tatva_dev_2026
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Kafka UI (Dev Tools) ---
KAFKA_UI_PORT=8090

# --- Application Secrets (DO NOT COMMIT .env with real values) ---
JWT_SECRET=change-me-in-production
JWT_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_HOURS=24
